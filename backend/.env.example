# ===========================================
# IndieYatra Backend Configuration
# Copy to .env and fill in your values
# ===========================================

# Server
PORT=8080
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://neondb_owner:npg_xxx@ep-xxx-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379
# Or use Upstash: rediss://default:xxx@xxx.upstash.io:6379

# JWT
JWT_SECRET=indieyatra-dev-secret-change-me-in-prod-32chars
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# LLM (choose one or leave blank for rule-based mock)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=mock

# Email (SMTP - leave blank to log tickets to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=tickets@indieyatra.in

# WhatsApp (Meta Business API - leave blank to log to console)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# SMS (Twilio - leave blank to log to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
